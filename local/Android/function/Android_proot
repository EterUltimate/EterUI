install_proot() {
	case "$(uname -m)" in
	aarch64)
		archurl="arm64"
		;;
	armv7l)
		archurl="armhf"
		;;
	x86_64)
		archurl="amd64"
		;;
	*)
		echo -e "\e[91m ❌ 错误：未知框架 \e[0m"
		exit
		;;
	esac
	mkdir -p "${HOME}/.termux/EterUl/proot"
	Proot_os_download_source="https://sgp1lxdmirror01.do.letsbuildthe.cloud/images"
	clear
	echo -e "\n\e[92m🎉 \e[1m【选择容器系统类型】\e[0m"
	sleep 0.1
	echo -e "\e[91m1. 🍎 Ubuntu\e[0m"
	sleep 0.1
	echo -e "\e[93m2. 🍥 Debian\e[0m"
	sleep 0.1
	echo -e "\e[95m3. 🥑 Kali\e[0m"
	sleep 0.1
	echo -e "\e[96m4. 🍐 Rockylinux\e[0m"
	sleep 0.1
	echo -e "\e[92m5. 🥝 CentOS\e[0m"
	sleep 0.1
	echo -e "\e[38;5;166m6. 🍇 Arch Linux\e[0m"
	sleep 0.1
	echo -e "\e[91m0. 🌚 退出\e[0m"
	read -p "请输入对应数字选择：" open_proot_os_list
	case ${open_proot_os_list} in
	1)
		open_ubuntu_os_list
		log "安装ubuntu系列"
		;;
	2)
		open_debian_os_list
		log "debian系列"
		;;
	3)
		open_kali_os_list
		log "安装kali系列"
		;;
	4)
		open_rockylinux_os_list
		log "安装rockylinux系列"
		;;
	5)
		open_centos_os_list
		log "安装centos系列"
		;;
	6)
		open_archlinux_os_list
		log "安装arch系列"
		;;		
	*)
		log "未选择退出"
		clear
		exit 1
		;;
	esac
	log "os_name: ${os_name}"
	log "Download_proot_NAME: ${Download_proot_NAME}"
	log "Download_proot_url: ${Download_proot_url}"
	wget_proot_url(){
		while [ $counter -lt $Maximum_number_of_attempts ]; do
			log "最大循环Maximum_number_of_attempts: $Maximum_number_of_attempts"
			log "当前循环counter= $counter"
			if wget -q --show-progress "${Download_proot_url}" -O "$download_file"; then
				echo -e "\e[92m✅ 成功：文件存储在 ${download_file} \e[0m"
				log "下载成功：$download_file"
				break
			else
				echo -e "\e[93m⚠️  警告：下载失败，尝试备用下载 \e[0m"
				log "下载失败：$download_file"
				if [ $counter -eq 0 ]; then
					Download_proot_url="https://dl.gancmcs.top/${Download_proot_url}"
					log "尝试使用备用 URL 下载，更新 Download_proot_url 为 \"$Download_proot_url\""
				fi
				if [ $counter -eq $((Maximum_number_of_attempts - 1)) ]; then
					echo -e "\e[91m❌ 错误：多次下载失败，请联系开发者解决！ \e[0m"
					exit 1
				fi
			fi
			((counter++))
		done
	}
	download_file="${HOME}/EterUl/download/${os_name}.tar.xz"
	if [ -f "$download_file" ] && [ $(du -b "$download_file" | cut -f1) -lt 41943040 ]; then
		echo -e "\e[93m⚠️  警告：${download_file} 可能已经损坏 \e[0m"
		log "\"${HOME}/EterUl/download/${os_name}.tar.xz\"文件损坏，重新下载"
		log "下载url:\"${Download_proot_url}\" 保存到 \"$download_file\""
		counter=0
		Maximum_number_of_attempts=2
		wget_proot_url
	elif [ -f "$download_file" ]; then
		log "\"${HOME}/EterUl/download/${os_name}.tar.xz\"存在且大于40MBB"
	else
		log "\"${HOME}/EterUl/download/${os_name}.tar.xz\"不存在"
		log "下载url:\"${Download_proot_url}\" 保存到 \"$download_file\""
		counter=0
		Maximum_number_of_attempts=2
		wget_proot_url
	fi
	echo -e "\e[94m提示：您可以使用 rm -rfv $download_file 来节省存储空间 \e[0m"
	unset LD_PRELOAD
	mkdir -p ${HOME}/.termux/EterUl/proot/${os_name}
	log "解压\"${HOME}/EterUl/download/${os_name}.tar.xz\""
	proot --link2symlink tar --overwrite -xJf ${HOME}/EterUl/download/${os_name}.tar.xz -C ${HOME}/.termux/EterUl/proot/${os_name}/ --exclude='dev' || :
	chmod 777 "${HOME}/.termux/EterUl/proot/${os_name}/root/"
	chmod 777 "${HOME}/.termux/EterUl/proot/${os_name}/proc/"
	echo -e "${GREEN}复制脚本到容器（Arch暂不支持Linux功能）${RES}"
	log "复制脚本到容器（Arch暂不支持Linux功能）"
	mkdir -p ${HOME}/.termux/EterUl/proot/${os_name}/root/EterUl
	mkdir -p ${HOME}/.termux/EterUl/.重要文件夹/sys/.empty
	mkdir -p ${HOME}/.termux/EterUl/.重要文件夹/dev/shm
	cp -r ${HOME}/EterUl/config ${HOME}/.termux/EterUl/proot/${os_name}/root/EterUl
	cp -r ${HOME}/EterUl/function ${HOME}/.termux/EterUl/proot/${os_name}/root/EterUl
	cp -r ${HOME}/EterUl/local ${HOME}/.termux/EterUl/proot/${os_name}/root/EterUl
	cp ${HOME}/EterUl/eterui.sh ${HOME}/.termux/EterUl/proot/${os_name}/root/EterUl
	cp ${HOME}/EterUl/git_push.sh ${HOME}/.termux/EterUl/proot/${os_name}/root/EterUl
	cp ${HOME}/EterUl/function/proot_proc/.* ${HOME}/.termux/EterUl/proot/${os_name}/proc/
	cp ${HOME}/EterUl/function/proot_optimization ${HOME}/.termux/EterUl/proot/${os_name}/root/优化.sh
	proot \
		--link2symlink -0 \
		--rootfs=${HOME}/.termux/EterUl/proot/${os_name}/ \
		--bind=/dev \
		--bind=/sys \
		--bind=/proc \
		--bind="${HOME}/.termux/EterUl/proot/${os_name}/proc/.loadavg:/proc/loadavg" \
		--bind="${HOME}/.termux/EterUl/proot/${os_name}/proc/.version:/proc/version" \
		--bind="${HOME}/.termux/EterUl/proot/${os_name}/proc/.uptime:/proc/uptime" \
		--bind="${HOME}/.termux/EterUl/proot/${os_name}/proc/.stat:/proc/stat" \
		--bind="${HOME}/.termux/EterUl/proot/${os_name}/proc/.vmstat:/proc/vmstat" \
		--bind="${HOME}/.termux/EterUl/proot/${os_name}/proc/.sysctl_entry_cap_last_cap:/proc/sysctl_entry_cap_last_cap" \
		--kernel-release="5.15.0" \
		-w /root /usr/bin/env \
		-i HOME=/root \
		PATH=/usr/local/sbin:/usr/local/bin:/bin:/usr/bin:/sbin:/usr/sbin:/usr/games:/usr/local/games \
		TERM=xterm-256color \
		LANG=zh_CN.UTF-8 \
		LC_CTYPE="zh_CN.UTF-8" \
		LC_NUMERIC="zh_CN.UTF-8" \
		LC_TIME="zh_CN.UTF-8" \
		LC_COLLATE="zh_CN.UTF-8" \
		LC_MONETARY="zh_CN.UTF-8" \
		LC_MESSAGES="zh_CN.UTF-8" \
		LC_PAPER="zh_CN.UTF-8" \
		LC_NAME="zh_CN.UTF-8" \
		LC_ADDRESS="zh_CN.UTF-8" \
		LC_TELEPHONE="zh_CN.UTF-8" \
		LC_MEASUREMENT="zh_CN.UTF-8" \
		LC_IDENTIFICATION="zh_CN.UTF-8" \
		/bin/bash 优化.sh
	log "优化脚本执行成功"
	log "退出容器"
}
start_proot() {
	list_dir ${HOME}/.termux/EterUl/proot
	case $user_choice in
	0)
		echo -e "${RED}QUIT${RES}"
		log "退出"
		;;
