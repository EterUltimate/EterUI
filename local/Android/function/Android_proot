rm_proot() {
	list_dir ${HOME}/.termux/EterUl/proot
	case $user_choice in
	0)
		echo -e "${RED}Quit${RES}"
		log "退出"
		;;
	*)
		if [ ! $? = 0 ]; then
			exit
		fi
		os_name=${list_items[$((user_choice - 1))]}
		op_type=$((RANDOM % 3 + 1))
		case $op_type in
			1)
				num1=$((RANDOM % 100))
				num2=$((RANDOM % 100))
				op_symbol="+"
				correct_result=$(($num1 + $num2))
				;;
			2)
				num1=$((RANDOM % 100 + 50))
				num2=$((RANDOM % 50))
				op_symbol="-"
				correct_result=$(($num1 - $num2))
				;;
			3)
				num1=$((RANDOM % 20 + 1))
				num2=$((RANDOM % 10 + 1))
				op_symbol="×"
				correct_result=$(($num1 * $num2))
				;;
		esac
		log "num1=$num1 op=$op_symbol num2=$num2 correct_result=$correct_result"
		read -e -p "🧮 真人验证：${num1}${op_symbol}${num2}=?" user_input
		log "user_input=$user_input"
		if ! [[ "$user_input" =~ ^[0-9]+$ ]]; then
			echo -e "\e[91m❌ 错误！请输入有效的数字答案 \e[0m"
			sleep 2
			clear
			exit 1
		fi
		if [ "$user_input" -eq "$correct_result" ]; then
			echo -e "\e[92m✅ 验证成功！继续操作 \e[0m"
			sleep 2
			chmod 777 -R "${HOME}/.termux/EterUl/proot/${os_name}/"
			rm -rfv "${HOME}/.termux/EterUl/proot/${os_name}/"
			echo -e "\e[92m✅ 删除完成，正在退出 \e[0m"
			sleep 2
			clear
		else
			echo -e "\e[91m❌ 错误！输入答案不正确，验证不通过 \e[0m"
			sleep 2
			clear
			exit 1
		fi
		;;
	esac
}
