zerotermux_install() {
    if ! command -v aria2c &> /dev/null; then
        echo -e "\033[34m检测到未安装aria2c，正在自动安装...\033[0m"
        pkg install -y aria2 > /dev/null 2>&1
    fi

    local APP_DIR="$HOME/EterUl/app"
    if [ ! -d "$APP_DIR" ]; then
        mkdir -p "$APP_DIR"
        echo -e "\033[34m检测到app文件夹不存在，已自动创建：$APP_DIR\033[0m"
    fi
   
    local DOWNLOAD_URL="https://gh.xmly.dev/https://github.com/hanxinhao000/ZeroTermux/releases/download/ZeroTermux-0.118.3.54/ZeroTermux-0.118.54-release_arm64-v8a.apk"
    local SAVE_PATH="EterUl/app/ZeroTermux-0.118.53-release_arm64-v8a.apk"

    echo -e "\033[36m=== 开始下载 ZeroTermux 安装包 ===\033[0m"
    echo -e "\033[36m保存路径：$SAVE_PATH\033[0m"
    aria2c --max-connection-per-server=8 "$DOWNLOAD_URL" -o "$SAVE_PATH"

    if [ $? -eq 0 ]; then
        echo -e "\033[32m✅ 下载成功！在 $HOME/EterUl/app 目录里找到即可\033[0m"
        sleep 3
    else
        echo -e "\033[31m❌ 下载失败！5秒后退出...\033[0m"
        sleep 5
        clear
        exit 1
    fi
}

