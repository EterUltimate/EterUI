android_store() {
    CHOICE=$(whiptail --clear --backtitle "DaLongZhuaZi" \
        --title "🐸 Android软件商店（Beta arm64）" \
        --menu "请选择:" 15 60 4 \
        1 "🖥 编程及终端代码类" \
        2 "☁️ 社交软件类" \
        3 "🤖 AI软件类" \
        4 "🌚 退出" \
    3>&1 1>&2 2>&3)
    
    case $CHOICE in
        1)
            log "编程及终端代码类"
            clear
            shell_classification
        ;;
        2)
            log "社交软件类"
            clear
            social_classification
        ;;
        3)
            log "AI软件类"
            clear
            ai_classification
        ;;        
        4)
            log "退出"
            clear
            exit 1
        ;;
        *)
            echo "${ERROR} 选择了未知选项，请重新进入菜单操作"
            sleep 3
            clear
            exit 1
        ;;
    esac
}

